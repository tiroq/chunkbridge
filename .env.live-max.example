# Live MAX API contract validation environment template.
# Copy this file to .env.live-max and fill in the values.
# NEVER commit .env.live-max — it is listed in .gitignore.
#
# See docs/live-max-validation.md for full instructions.

# Required: set to 1 to enable live tests.
CHUNKBRIDGE_LIVE_MAX_TESTS=1

# Required: root URL of the MAX Bot API (no trailing slash).
CHUNKBRIDGE_MAX_BASE_URL=https://platform-api.max.ru

# Required: bearer token. Leave blank here — fill in .env.live-max only.
CHUNKBRIDGE_MAX_TOKEN=

# Required: the chat ID that will receive test messages.
CHUNKBRIDGE_MAX_PEER_CHAT_ID=

# Optional: server-side long-poll timeout in seconds (default: 5 for live tests).
# CHUNKBRIDGE_MAX_POLL_TIMEOUT_SEC=5

# Optional: set to 1 to also validate the receive/poll path.
# Requires an inbound message from the peer within the 15-second test window.
# CHUNKBRIDGE_MAX_EXPECT_RECEIVE=1
